{
  "openapi": "3.0.0",
  "info": {
    "title": "TESSERA API",
    "description": "AI Security Testing Platform - REST API",
    "version": "1.0.0"
  },
  "servers": [
    {"url": "http://localhost:8000", "description": "Development"}
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": {"200": {"description": "OK"}}
      }
    },
    "/api/v1/scans": {
      "get": {
        "summary": "List scans",
        "responses": {
          "200": {
            "description": "List of scans",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"$ref": "#/components/schemas/Scan"}
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create scan",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/ScanRequest"}
            }
          }
        },
        "responses": {"201": {"description": "Scan created"}}
      }
    },
    "/api/v1/findings": {
      "get": {
        "summary": "List findings",
        "parameters": [
          {"name": "scan_id", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {"200": {"description": "List of findings"}}
      }
    },
    "/api/v1/topology": {
      "post": {
        "summary": "Load topology",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {"type": "object"}
            }
          }
        },
        "responses": {"200": {"description": "Topology loaded"}}
      }
    }
  },
  "components": {
    "schemas": {
      "Scan": {
        "type": "object",
        "properties": {
          "scan_id": {"type": "string"},
          "system": {"type": "string"},
          "tier": {"type": "integer"},
          "status": {"type": "string"},
          "created_at": {"type": "string"}
        }
      },
      "ScanRequest": {
        "type": "object",
        "required": ["topology", "tier"],
        "properties": {
          "topology": {"type": "object"},
          "tier": {"type": "integer"},
          "backbone": {"type": "string"}
        }
      }
    }
  }
}